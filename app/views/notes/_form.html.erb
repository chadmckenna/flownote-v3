<%= form_with(model: note, url: form_url) do |form| %>
  <% if note.errors.any? %>
    <div role="alert" data-variant="error">
      <% note.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="note-form__heading">
    <%= form.text_field :title, required: true, placeholder: "Title", "aria-label": "Title" %>
    <menu class="buttons">
      <%= form.submit "Save" %>
      <% if note.persisted? %>
        <%= link_to "View", folder_note_path(note.folder, note), data: { turbo_frame: "editor_main", turbo_action: "advance" }, class: "button outline" %>
      <% end %>
      <% if local_assigns[:cancel_path] %>
        <%= link_to "Close", cancel_path, class: "button outline" %>
      <% end %>
    </menu>
  </div>

  <% if local_assigns[:show_folder_select] %>
    <%= form.label :folder_id, "Folder" %>
    <%= form.select :folder_id, folder_options_for_select(Current.user, note.folder_id) %>
  <% else %>
    <%= form.hidden_field :folder_id %>
  <% end %>

  <div data-controller="vim-editor">
    <%= form.text_area :body, rows: 24, placeholder: "Write in Markdown...",
                              data: { vim_editor_target: "textarea" } %>
  </div>
<% end %>
