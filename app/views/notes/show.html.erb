<article>
  <nav aria-label="breadcrumb" class="breadcrumb-heading">
    <ul>
      <li><%= link_to "~", root_path %></li>
      <% @note.folder.ancestors.reject(&:root?).each do |ancestor| %>
        <li><%= link_to ancestor.name, ancestor %></li>
      <% end %>
      <% unless @note.folder.root? %>
        <li><%= link_to @note.folder.name, @note.folder %></li>
      <% end %>
      <li aria-current="page"><%= @note.title %></li>
    </ul>
  </nav>

  <div><%= @note.body %></div>

  <menu class="buttons">
    <%= link_to "Edit", edit_folder_note_path(@note.folder, @note), class: "button" %>
    <%= link_to "Back", @note.folder.root? ? root_path : folder_path(@note.folder), class: "button outline" %>
    <%= button_to "Delete", folder_note_path(@note.folder, @note), method: :delete, class: "button ghost danger-text",
        form: { class: "buttons-right" },
        data: { turbo_confirm: "Are you sure?" } %>
  </menu>
</article>
