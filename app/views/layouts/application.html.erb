<!DOCTYPE html>
<html>
  <%= render "layouts/shared/head" %>

  <body>
    <%= render "topnav/topnav" %>

    <% if folder_shell? %>
      <main class="folder-shell">
        <%= turbo_stream_from @folder %>
        <%= turbo_stream_from @note if @note %>

        <%= render "topnav/context" %>
        <%= render "sidebar/sidebar" %>
        <div class="folder-shell__main"><%= yield %></div>
      </main>
    <% else %>
      <main class="container">
        <%= render "layouts/shared/flashes" %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
