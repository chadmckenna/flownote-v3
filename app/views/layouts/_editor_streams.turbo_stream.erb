<%= turbo_stream_action_tag :advance_url, url: request.path %>
<%= turbo_stream.replace "folder_context" do %>
  <%= turbo_frame_tag "folder_context" do %>
    <%= render "topnav/context" %>
    <%= render "sidebar/sidebar" %>
  <% end %>
<% end %>
<%= turbo_stream.replace "editor_main" do %>
  <%= turbo_frame_tag "editor_main", class: "folder-shell__main" do %>
    <%= yield %>
  <% end %>
<% end %>
