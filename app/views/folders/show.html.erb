<nav aria-label="breadcrumb">
  <ul>
    <li><%= link_to "Notes", root_path %></li>
    <% @ancestors.reject(&:root?).each do |ancestor| %>
      <li><%= link_to ancestor.name, ancestor %></li>
    <% end %>
    <li aria-current="page"><%= @folder.name %></li>
  </ul>
</nav>

<h1><%= @folder.name %></h1>

<menu class="buttons">
  <%= link_to "New note", new_folder_note_path(@folder), class: "button" %>
  <%= link_to "New folder", new_folder_path(parent_id: @folder.id), class: "button outline" %>
  <%= link_to "Edit folder", edit_folder_path(@folder), class: "button ghost" %>
</menu>

<% @subfolders.each do |folder| %>
  <article class="card">
    <header>
      <h3><%= link_to folder.name, folder %></h3>
    </header>
  </article>
<% end %>

<% @notes.each do |note| %>
  <article class="card">
    <header>
      <h3><%= link_to note.title, folder_note_path(@folder, note) %></h3>
    </header>
    <p><small>Updated <%= time_ago_in_words(note.updated_at) %> ago</small></p>
  </article>
<% end %>

<% if @subfolders.empty? && @notes.empty? %>
  <p>This folder is empty.</p>
<% end %>
