<div class="folder-shell__pane" data-mode="viewing">
  <menu class="buttons">
    <%= link_to "Edit", edit_folder_note_path(note.folder, note),
        data: { turbo_frame: "editor_main", turbo_action: "advance" },
        class: "button" %>
    <%= link_to "Close", folder_or_root_path(note.folder),
        data: { turbo_stream: true, turbo_action: "advance" },
        class: "button outline" %>
    <%= button_to "Delete", folder_note_path(note.folder, note), method: :delete,
        class: "button ghost danger-text",
        form: { class: "buttons-right", data: { turbo_frame: "_top" } },
        data: { turbo_confirm: "Are you sure?" } %>
  </menu>

  <article class="prose"><%= render_markdown(note.body) %></article>
</div>
